<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingBottom="40dp"
    android:padding="16dp"
    android:background="@drawable/bottom_sheet_background"
    tools:context=".ui.profile.EditProfileFragment">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="@color/divider_color" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        app:cardBackgroundColor="@color/card_background"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/border_color"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="32dp"
            android:paddingBottom="28dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">


            <!-- Avatar with ring -->
            <FrameLayout
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_gravity="center_horizontal">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/profileImage"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop"
                    android:src="@drawable/girl_avatar"
                    app:shapeAppearance="@style/CircleImageView" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_profile_avatar_ring" />

                <View
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="110dp"
                    android:layout_marginTop="110dp"
                    android:background="@drawable/bg_icon_container" />

                <View
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:backgroundTint="@color/brand_primary"
                    android:layout_marginStart="116dp"
                    android:layout_marginTop="116dp"
                    android:background="@drawable/edit_24px" />

            </FrameLayout>

            <!-- Username -->
            <LinearLayout
                android:layout_marginTop="20dp"
                android:padding="8dp"
                android:gravity="center_vertical"
                android:background="@drawable/textview_border"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <EditText
                    android:id="@+id/profileUsername"
                    android:layout_width="0dp"
                    android:layout_weight="9"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start"
                    android:fontFamily="sans-serif-medium"
                    android:hint="@string/android_user"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp" />

                <ImageView
                    android:id="@+id/editUsername"
                    android:src="@drawable/edit_24px"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <!-- Email -->
            <LinearLayout
                android:layout_marginTop="20dp"
                android:padding="8dp"
                android:gravity="center_vertical"
                android:background="@drawable/textview_border"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <EditText
                    android:id="@+id/profileEmail"
                    android:layout_width="0dp"
                    android:layout_weight="9"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start"
                    android:fontFamily="sans-serif-medium"
                    android:hint="@string/user_email"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp" />

                <ImageView
                    android:id="@+id/editEmail"
                    android:src="@drawable/edit_24px"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"/>

            </LinearLayout>


        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>


    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        app:cardBackgroundColor="@color/card_background"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/border_color"
        app:strokeWidth="1dp">

        <!-- Password -->
        <LinearLayout
            android:id="@+id/changePassword"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="9"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:fontFamily="sans-serif-medium"
                android:text="@string/change_password"
                android:textColor="@color/text_secondary"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/editPassword"
                android:src="@drawable/arrow_forward_ios_24px"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>


</LinearLayout>